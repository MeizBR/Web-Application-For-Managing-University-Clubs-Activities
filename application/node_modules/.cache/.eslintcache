' src='images/aero.png' alt='club image' /></td>\r\n                  <td>15 DT</td>\r\n              </tr>\r\n              <tr class=\"active-row\">\r\n                  <td>Google Developers Students</td>\r\n                  <td><img className='club-photo' src='images/google.png' alt='club image' /></td>\r\n                  <td>Free</td>\r\n              </tr>\r\n              <tr class=\"active-row\">\r\n                  <td>IEEE Student Branch</td>\r\n                  <td><img className='club-photo' src='images/ieee.jpg' alt='club image' /></td>\r\n                  <td>46 DT</td>\r\n              </tr>\r\n              <tr class=\"active-row\">\r\n                  <td>Junior Entreprise Students</td>\r\n                  <td><img className='club-photo' src='images/junior.jpg' alt='club image' /></td>\r\n                  <td>35 DT</td>\r\n              </tr>\r\n\r\n              <tr class=\"active-row\">\r\n                  <td>Microsoft Tech Club ( MTC )</td>\r\n                  <td><img className='club-photo' src='images/mtc.jpg' alt='club image' /></td>\r\n                  <td>25 DT</td>\r\n              </tr>\r\n              <tr class=\"active-row\">\r\n                  <td>Nateg</td>\r\n                  <td><img className='club-photo' src='images/nateg.jpg' alt='club image' /></td>\r\n                  <td>35 DT</td>\r\n              </tr>\r\n\r\n              <tr class=\"active-row\"> \r\n                  <td>Orbeats</td>\r\n                  <td><img className='club-photo' src='images/orbeats.jpg' alt='club image' /></td>\r\n                  <td>15 DT</td>\r\n              </tr>\r\n              <tr class=\"active-row\">\r\n                  <td>Robotics ( CR )</td>\r\n                  <td><img className='club-photo' src='images/robotics.jpg' alt='club image' /></td>\r\n                  <td>30 DT</td>\r\n              </tr>\r\n          </tbody>\r\n        </table>\r\n    </div>\r\n  )\r\n}\r\n","D:\\PFA Project\\PFA new version 1\\PFA new version\\application\\src\\components\\Feedback\\Feedback.js",["216","217"],[],"import React from 'react'\r\nimport './Feedback.css'\r\nimport { Link } from \"react-router-dom\";\r\nimport Axios from \"axios\"\r\nimport { useState, useEffect } from 'react'\r\nimport Rating from 'react-rating-stars-component';\r\n\r\nexport const Feedback = () => {\r\n\r\n    // useState to make API data extraction synchronous\r\n  const [feedbacks, setfeedback] = useState([])\r\n\r\n  useEffect(() => {\r\n    // call the API by Axios to display feedbacks in the collection feedbacks in the PFA DB here\r\n    Axios.get(\"http://localhost:5000/feedbacks\")\r\n    .then(res => {\r\n      setfeedback(res.data)\r\n    })\r\n  }, [])\r\n\r\n  return (\r\n    <div className='container feedback-container'>\r\n        <h3 className='feedback-title'>Some Trainings Feedbacks Shared By Our Students</h3>\r\n\r\n    <div className='row'>\r\n      {feedbacks.slice(0,3).map(feedback => {\r\n        return(\r\n          <div className='col-3 container'>\r\n          <div class=\"card_bg-light\" style={{width: \"100%\",}} key={feedback._id}>\r\n          <img src=\"images/FEEDBACKICON.png\"   className=\"card-img-top\" alt=\"feedback-image\" />\r\n            <div className=\"card-body1\">\r\n              <h5 className=\"card-title\" style={{fontFamily:\"serif\" , color:\"black\" ,fontSize:\"19px\"}}> Formation Name : {feedback.formationName}</h5>\r\n              <h6 className=\"card-text\" style={{color:\"white\",}}>Trainer  : {feedback.formateurFirstName} {feedback.formateurLastName}</h6>\r\n              <h6 className=\"card-text\" style={{color:\"white\",}}>Student  : {feedback.studentFirstName} {feedback.studentLastName}</h6>\r\n              <h6 className=\"card-text\" style={{color:\"white\" }}>Section : {feedback.studentSection}</h6>\r\n              <h6 className=\"card-text\" style={{color:\"white\" }}>Content : {feedback.feedbackContent}</h6>\r\n              <h6 className=\"card-text\" 