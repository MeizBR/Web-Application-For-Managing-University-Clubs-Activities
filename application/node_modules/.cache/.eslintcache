App.js",[],[],[],"D:\\PFA Project\\PFA new version 1\\PFA new version\\application\\src\\Pages\\WorkshopsPage\\WorkshopsPage.js",[],[],"D:\\PFA Project\\PFA new version 1\\PFA new version\\application\\src\\Pages\\FormationPage\\FormationElement.js",["174"],[],"D:\\PFA Project\\PFA new version 1\\PFA new version\\application\\src\\Pages\\FormationPage\\FormationsPage.js",[],[],"D:\\PFA Project\\PFA new version 1\\PFA new version\\application\\src\\Pages\\FeedbackPage\\FeedbackPage.js",["175"],[],"D:\\PFA Project\\PFA new version 1\\PFA new version\\application\\src\\Pages\\Organisation\\Organisation.js",[],[],"D:\\PFA Project\\PFA new version 1\\PFA new version\\application\\src\\Pages\\Users\\Users.js",[],[],"D:\\PFA Project\\PFA new version 1\\PFA new version\\application\\src\\Pages\\WorkshopsPage\\WorkshopElement.js",["176"],[],"import React from 'react'\r\nimport { useEffect, useState } from 'react';\r\nimport { Link, useParams } from 'react-router-dom';\r\nimport Axios from 'axios'; \r\nimport './WorkshopElement.css'\r\nimport { Navbar } from '../../components/Navbar/Navbar';\r\nimport { Footer } from '../../sections/Footer/Footer';\r\n\r\nexport const WorkshopElement = () => {\r\n\r\n  const { id } = useParams();\r\n  const [workshop, setWorkshop] = useState([]);\r\n\r\n  useEffect(() => {\r\n    Axios\r\n      .get(`http://localhost:5000/workshops/${id}`)\r\n      .then((res) => setWorkshop(res.data))\r\n      .catch((err) => console.log(err));\r\n  }, [id]);\r\n\r\n  // useState to make API data extraction synchronous : for inscriptions\r\n  const [studentFirstName, setStudentFirstName] = useState(\"\")\r\n  const [studentLastName, setStudentLastName] = useState(\"\")\r\n  const [studentEmail, setStudentEmail] = useState(\"\")\r\n  const [studentSection, setStudentSection] = useState(\"\")\r\n  const [studentCode, setStudentCode] = useState(\"\");\r\n\r\n\r\n\r\n  const [allowedCodes, setAllowedCodes] = useState([]);\r\n  const [allowedFirstNames, setAllowedFirstNames] = useState([]);\r\n  const [allowedLastNames, setAllowedLastNames] = useState([]);\r\n  const [allowedSections, setAllowedSections] = useState([]);\r\n  const [allowedEmails, setAllowedEmails] = useState([]);\r\n\r\n\r\n  const [inscriptionsCount, setInscriptionsCount] = useState(0);\r\n  const [isButtonDisabled, setIsButtonDisabled] = useState(false);\r\n\r\n  // extract the students data\r\n  useEffect(() => {\r\n    Axios\r\n      .get(\"http://localhost:5000/students\")\r\n      .then((res) => {\r\n        const codes = res.data.map((student) => student.studentCode);\r\n        const firstnames = res.data.map((student) => student.studentFirstName);\r\n        const lastnames = res.data.map((student) => student.studentLastName);\r\n        const sections = res.data.map((student) => student.studentSection);\r\n        const emails = res.data.map((student) => student.studentEmail);\r\n        setAllowedCodes(codes);\r\n        setAllowedFirstNames(firstnames);\r\n        setAllowedLastNames(lastnames);\r\n        setAllowedSections(sections);\r\n        setAllowedEmails(emails)\r\n\r\n      })\r\n      .catch((err) => console.log(err));\r\n  }, []);\r\n\r\n\r\n    // Get the inscriptions count from the backend when component mounts\r\n    useEffect(() => {\r\n      if (workshop._id) {\r\n      Axios.get(`http://localhost:5000/workshops/${workshop._id}`)\r\n        .then(res => {\r\n          const storedCount = res.data.inscriptionsCount;\r\n          if (storedCount) {\r\n            setInscriptionsCount(storedCount);\r\n          }\r\n        })\r\n        .catch(err => console.log(err));\r\n      }\r\n    }, [workshop._id]);\r\n\r\n\r\n  useEffect(() => {\r\n    if (inscriptionsCount >= workshop.workshopCapacity) {\r\n      setIsButtonDisabled(true);\r\n    }\r\n  }, [inscriptionsCount, workshop.workshopCapacity]);\r\n\r\n    const submitInscription = () => {\r\n\r\n    if (inscriptionsCount <= workshop.workshopCapacity) {\r\n      if(\r\n        studentFirstName.trim() !== '' &&\r\n        studentLastName.trim() !== '' &&\r\n        studentEmail.trim() !== '' &&\r\n        studentEmail.match(/^[\\w-\\.]+@([\\w-]+\\.)+[\\w-]{2,4}$/) &&\r\n        studentSection !== '' &&\r\n        !isNaN(studentCode)\r\n      ) {\r\n        const capitalizedFirstName = studentFirstName.toLowerCase().replace(/^\\w/, (c) => c.toUpperCase());\r\n        const capitalizedLastName = studentLastName.toLowerCase().replace(/^\\w/, (c) => c.toUpperCase());\r\n        if (\r\n          allowedCodes.includes(Number(studentCode)) &&\r\n          allowedFirstNames.includes(studentFirstName) &&\r\n          allowedLastNames.includes(studentLastName) &&\r\n          allowedSections.includes(studentSection) &&\r\n          allowedEmails.includes(studentEmail)\r\n        ) {\r\n            Axios.post(\"http://localhost:5000/submitAnInscriptionWorkshop\", {\r\n              workshopName : workshop.workshopName,\r\n              workshopId : workshop._id,\r\n              formateurFirstName : workshop.formateurFirstName,\r\n              formateurLastName : workshop.formateurLastName,\r\n              studentFirstName : capitalizedFirstName,\r\n              studentLastName : capitalizedLastName,\r\n              studentEmail : studentEmail,\r\n              studentSection : studentSection,\r\n              studentCode: studentCode,\r\n              })\r\n              .then(res => {\r\n                  alert(\"Inscription submitted successfully\")\r\n                  console.log(res.data);\r\n                  setStudentFirstName(\"\");\r\n                  setStudentLastName(\"\");\r\n                  setStudentEmail(\"\");\r\n                  setStudentCode(\"\");\r\n                  setStudentSection(\"\");\r\n                  document.getElementById(\"myForm\").reset();\r\n                  document.getElementById(\"section\").selectedIndex = 0;\r\n              })\r\n              .catch((err) => {\r\n                if (err.response && err.response.status === 400) {\r\n                  alert(err.response.data.message);\r\n                  document.getElementById(\"myForm\").reset();\r\n                  document.getElementById(\"section\").selectedIndex = 0;\r\n                } else {\r\n                  console.log(err);\r\n                  alert(\"An error occurred. Please try again later.\");\r\n                }\r\n              });\r\n          } else {\r\n            alert(\"This student does not exist. Please make sure you are from our family\");\r\n          }\r\n    } else {\r\n      alert(\"Please fill in all required fields or make sure you are providing valid information\");\r\n    }\r\n} else {\r\n  alert(\"The formation is already full. Make sure you will come earlier in next events\");\r\n  }\r\n  }\r\n\r\n\r\n\r\n\r\n  return ( \r\n   <div>\r\n    <Navbar/>\r\n   \r\n    <div style={{display:'flex' }}>\r\n\r\n      <div className='workshopComponentDe'>\r\n      <h1 className=\"title88\">  Let's get started with your registration </h1>\r\n      <ul className=\"custom-bullets\">\r\n      <li>Please fill out the form ahead </li>\r\n      <li>Double Check all the information you inserted </li>  \r\n      <li>Click Enroll Now to Register </li> \r\n      </ul>\r\n      </div>\r\n\r\n\r\n      <div className='workshopComponentUN'>\r\n         <div className='Lastt'>\r\n      <h1 className='WorkshopElementName'>{workshop.workshopName}</h1>\r\n      <p style={{ fontWeight: 'bold', color: 'black' }}><span style={{fontSize: '20px'}}>Workshop Date : </span>{workshop.workshopDate}</p>\r\n      <p style={{ fontWeight: 'bold', color: 'black' }}> <span style={{fontSize: '20px'}}>Workshop Room : </span>{workshop.room}</p>\r\n      <p style={{ fontWeight: 'bold', color: 'black' }}> <span style={{fontSize: '20px'}}>Workshop Capacity : </span>{workshop.workshopCapacity}</p>\r\n      <p style={{ fontWeight: 'bold', color: 'black' }}> <span style={{fontSize: '20px'}}>Workshop Start Hour : </span> {workshop.startHour}</p>\r\n      <p style={{ fontWeight: 'bold', color: 'black' }}> <span style={{fontSize: '20px'}}>Formateur : </span> {workshop.formateurFirstName} {workshop.formateurLastName}</p>\r\n      </div>\r\n\r\n      <form>\r\n      <h5>Make An Inscription !</h5>\r\n\r\n      <input required type='text' placeholder='First Name' onChange={e => setStudentFirstName(e.target.value)}  style={{width: '350px', height: '50px', marginBottom:\"10px\"}}/> <br/>\r\n      <input required type='text' placeholder='Last Name' onChange={e => setStudentLastName(e.target.value)}style={{width: '350px', height: '50px', marginBottom:\"10px\"}} /><br/>\r\n      <input required type='email' placeholder=' Email' onChange={e => setStudentEmail(e.target.value)} style={{width: '350px', height: '50px', marginBottom:\"10px\"}}/><br/>\r\n      \r\n      \r\n      <input required\r\n        type=\"text\"\r\n        placeholder=\"Student code\"\r\n        onChange={(e) => setStudentCode(e.target.value)}style={{width: '350px', height: '50px', marginBottom:\"10px\"}}/><br/> \r\n      \r\n      \r\n      <select style={{width: '350px', height: '50px', marginBottom:\"10px\"}} required id='section'  onChange={e => setStudentSection(e.target.value)}>\r\n        <option disabled selected value=\"\">Please select a section</option>\r\n        <option value='GT'>GT</option>\r\n        <option value='GII'>GII</option>\r\n        <option value='GEC'>GEC</option>\r\n        <option value='IDSD'>IDSD</option>\r\n      </select><br/>\r\n      <button onClick={submitInscription} disabled={isButtonDisabled}>Enroll now !</button>\r\n      </form> <br/>\r\n\r\n      <div className='btn btn-outline-primary' id='return-to-link'><Link to='/workshops'>Return to workshops page</Link></div>\r\n        \r\n      </div>\r\n      \r\n    </div>\r\n\r\n    <Footer />\r\n    </div>\r\n  )\r\n}\r\n","D:\\PFA Project\\PFA new version 1\\PFA new version\\application\\src\\Pages\\FeedbackWorkshops\\FeedbackWorkshops.js",["177"],[],"import './FeedbackWorkshops.css';\r\nimport Axios from \"axios\";\r\nimport { React, useState, useEffect } from 'react'\r\nimport Rating from 'react-rating-stars-component';\r\nimport { Header } from '../../sections/Header/Header';\r\nimport { Footer } from '../../sections/Footer/Footer';\r\n\r\nexport const FeedbackWorkshops = () => {\r\n\r\n  const [workshops, setWorkshop] = useState([]);\r\n\r\n  // useEffect to make API data extraction synchronous\r\n  useEffect(() => {\r\n    Axios\r\n      .get(\"http://localhost:5000/workshops\")\r\n      .then((res) => setWorkshop(res.data))\r\n      .catch((err) => console.log(err));\r\n  });\r\n\r\n  const [feedbacksworkshops, setFeedbackWorkshop] = useState([])\r\n\r\n  const [workshopName, setWorkshopName] = useState(\"\")\r\n  const [formateurFirstName, setFormateurFirstName] = useState(\"\")\r\n  const [formateurLastName, setFormateurLastName] = useState(\"\")\r\n  const [studentFirstName, setStudentFirstName] = useState(\"\")\r\n  const [studentLastName, setStudentLastName] = useState(\"\")\r\n  const [studentEmail, setStudentEmail] = useState(\"\")\r\n  const [studentSection, setStudentSection] = useState(\"\")\r\n  const [studentCode, setStudentCode] = useState(\"\")\r\n  const [feedbackContent, setFeedbackContent] = useState(\"\")\r\n  const [feedbackRating, setFeedbackRating] = useState(0);\r\n\r\n  const [allowedCodes, setAllowedCodes] = useState([]);\r\n  const [allowedFirstNames, setAllowedFirstNames] = useState([]);\r\n  const [allowedLastNames, setAllowedLastNames] = useState([]);\r\n  const [allowedSections, setAllowedSections] = useState([]);\r\n  const [allowedEmails, setAllowedEmails] = useState([]);\r\n\r\n  // extract the students data\r\n  useEffect(() => {\r\n    Axios\r\n      .get(\"http://localhost:5000/students\")\r\n      .then((res) => {\r\n        const codes = res.data.map((student) => student.studentCode);\r\n        const firstnames = res.data.map((student) => student.studentFirstName);\r\n        const lastnames = res.data.map((student) => student.studentLastName);\r\n        const sections = res.data.map((student) => student.studentSection);\r\n        const emails = res.data.map((student) => student.studentEmail);\r\n        setAllowedCodes(codes);\r\n        setAllowedFirstNames(firstnames);\r\n        setAllowedLastNames(lastnames);\r\n        setAllowedSections(sections);\r\n        setAllowedEmails(emails);\r\n\r\n      })\r\n      .catch((err) => console.log(err));\r\n  }, []);\r\n\r\n  const handleWorkshopChange = (e) => {\r\n    // Get the selected workshop\r\n    const selectedWorkshop = workshops.find(\r\n      (workshop) => workshop.workshopName === e.target.value\r\n    );\r\n    // Set the state with the formateurFirstName and formateurLastName associated with the selected workshop\r\n    setWorkshopName(selectedWorkshop.workshopName);\r\n    setFormateurFirstName(selectedWorkshop.formateurFirstName);\r\n    setFormateurLastName(selectedWorkshop.formateurLastName);\r\n  };\r\n\r\n  // define the function submitFeedback\r\n  const submitFeedback = () => {\r\n    if(\r\n        workshopName !== '' &&\r\n        studentFirstName.trim() !== '' &&\r\n        studentLastName.trim() !== '' &&\r\n        studentEmail.trim() !== '' &&\r\n        studentEmail.match(/^[\\w-\\.]+@([\\w-]+\\.)+[\\w-]{2,4}$/) &&\r\n        studentSection !== '' &&\r\n        studentCode.trim() !== '' &&\r\n        !isNaN(studentCode) &&\r\n        feedbackContent.trim() !== '' &&\r\n        feedbackRating !== '' &&\r\n        feedbackRating !== null\r\n      ) {\r\n        const capitalizedFirstName = studentFirstName.toLowerCase().replace(/^\\w/, (c) => c.toUpperCase());\r\n        const capitalizedLastName = studentLastName.toLowerCase().replace(/^\\w/, (c) => c.toUpperCase());\r\n          if (\r\n            allowedCodes.includes(Number(studentCode)) &&\r\n            allowedFirstNames.includes(studentFirstName) &&\r\n            allowedLastNames.includes(studentLastName) &&\r\n            allowedSections.includes(studentSection) &&\r\n            allowedEmails.includes(studentEmail)\r\n          ) {\r\n              Axios.post(\"http://localhost:5000/submitAWorkshopFeedback\", {\r\n                    workshopName : workshopName,\r\n                    formateurFirstName : formateurFirstName,\r\n                    formateurLastName : formateurLastName,\r\n                    studentFirstName : capitalizedFirstName,\r\n                    studentLastName : capitalizedLastName,\r\n                    studentEmail : studentEmail,\r\n                    studentSection : studentSection,\r\n                    studentCode: studentCode,\r\n                    feedbackContent : feedbackContent,\r\n                    feedbackRating : feedbackRating,\r\n                    createdAt : new Date()\r\n                })\r\n                .then(res => {\r\n                    alert(\"Feedback submitted successfully\");\r\n                    console.log(res.data);\r\n                    setStudentFirstName(\"\");\r\n                    setStudentLastName(\"\");\r\n                    setStudentEmail(\"\");\r\n                    setStudentSection(\"\");\r\n                    setStudentCode(\"\");\r\n                    document.getElementById(\"myForm\").reset();\r\n                    document.getElementById(\"section\").selectedIndex = 0;\r\n                })\r\n                .catch((err) => {\r\n                  if (err.response && err.response.status === 404) {\r\n                    alert(err.response.data.message);\r\n                } else {\r\n                    console.log(err);\r\n                    alert(\"An error occurred. Please try again later.\");\r\n                }\r\n                });\r\n          } else {\r\n            alert(\"This student does not exist. Please make sure you are from our family\");\r\n          }\r\n      } else {\r\n        alert(\"Please fill in all required fields or make sure you are providing valid information\");\r\n    }\r\n  }\r\n\r\n  // Fetch feedbacks data\r\n useEffect(() => {\r\n  Axios.get(\"http://localhost:5000/feedbacksWorkshops\")\r\n    .then((res) => setFeedbackWorkshop(res.data))\r\n    .catch((err) => console.log(err));\r\n}, []);\r\n\r\nconst calculatePercentage = (workshopName, rating) => {\r\n  const workshopFeedbacks = feedbacksworkshops.filter(\r\n    (feedbacksworkshop) => feedbacksworkshop.workshopName === workshopName\r\n  );\r\n  const totalFeedbacks = workshopFeedbacks.length;\r\n  const ratingFeedbacks = workshopFeedbacks.filter(\r\n    (feedbacksworkshop) => feedbacksworkshop.feedbackRating === rating\r\n  );\r\n  const percentage =\r\n    (ratingFeedbacks.length / totalFeedbacks) * 100 || 0; // handle divide by zero error\r\n  return percentage.toFixed(2); // round to two decimal places\r\n};\r\n\r\n\r\n\r\n\r\n\r\n  return (\r\n    <>\r\n        <Header />\r\n        <div style={{marginTop:\"35px\"}} className='titrFeedback'>\r\n          <h1>WorkshopsFeedbacks</h1>\r\n        </div>\r\n        <div style={{display:'flex' }}>\r\n        <div className=\"welcomec\">\r\n    \r\n              <h1 className=\"title5\"> Your thoughts are important to us, please let us know what you think ! </h1>\r\n              <ul className=\"custom-bullets\">\r\n                    <li>Please fill out the form ahead </li>\r\n                   <li>Look bellow to see our best </li>  \r\n         </ul>\r\n          </div>\r\n         <div>\r\n          <form id='myForm' className='feedback-form-container'>\r\n          <legend> Please don't hesitate !</legend>\r\n          <table>\r\n            <tbody>\r\n              <tr>\r\n                <td><label>Workshop</label></td>\r\n                <td>\r\n                  <select style={{width:\"100%\"}} id='section' onChange={handleWorkshopChange} >\r\n                    <option disabled selected value=\"\">Please select a workshop to rate</option>\r\n                  {workshops.map(workshop => {\r\n                    return(\r\n                          <option key={workshop._id} value={workshop.workshopName}>{workshop.workshopName}</option>\r\n                    )\r\n                  })}\r\n                  </select>\r\n                </td>\r\n              </tr>\r\n              <tr>\r\n                <td><label>Student first name</label></td>\r\n                <td><input style={{width:\"100%\"}} type=\"text\" required onChange={e => setStudentFirstName(e.target.value)} /></td>\r\n              </tr>\r\n              <tr>\r\n                <td><label>Student last name</label></td>\r\n                <td><input style={{width:\"100%\"}} type=\"text\" required onChange={e => setStudentLastName(e.target.value)} /></td>\r\n              </tr>\r\n              <tr>\r\n                <td><label>Student email</label></td>\r\n                <td><input style={{width:\"100%\"}} type=\"email\" required onChange={e => setStudentEmail(e.target.value)} /></td>\r\n              </tr>\r\n              <tr>\r\n                <td><label>Student code</label></td>\r\n                <td><input style={{width:\"100%\"}} type=\"text\" required onChange={e => setStudentCode(e.target.value)} /></td>\r\n              </tr>\r\n              <tr>\r\n                <td><label>Student section</label></td>\r\n                <td>\r\n                  <select style={{width:\"100%\"}} id='section'  onChange={e => setStudentSection(e.target.value)}>\r\n                    <option disabled selected value=\"\">Please select your section</option>\r\n                    <option value='GT'>GT</option>\r\n                    <option value='GII'>GII</option>\r\n                    <option value='GEC'>GEC</option>\r\n                    <option value='IDSD'>IDSD</option>\r\n                  </select>\r\n                </td>\r\n              </tr>\r\n              <tr>\r\n                <td><label>Feedback content</label></td>\r\n                <td><textarea style={{width:\"100%\"}} cols=\"40\" rows=\"8\" required onChange={e => setFeedbackContent(e.target.value)} /></td>\r\n              </tr>\r\n              <tr>\r\n                <td><label>Select you satisfaction level</label></td>\r\n                <td>\r\n                <Rating\r\n                  count={6}\r\n                  size={60}\r\n                  activeColor=\"RED\"\r\n                  color=\"GRAY\"\r\n                  value={feedbackRating}\r\n                  onChange={e => setFeedbackRating(e)}\r\n                />\r\n                </td>\r\n              </tr>\r\n              <tr>\r\n                <td colSpan={2}><button onClick={submitFeedback}>Submit</button></td>\r\n              </tr>\r\n            </tbody>\r\n          </table>\r\n      </form>\r\n          </div>\r\n    \r\n          \r\n        </div>\r\n\r\n\r\n        <h3>Rating Statistics</h3>\r\n\r\n          {workshops.map((workshop) => (\r\n  <div className='progress-bar-container' key={workshop._id}>\r\n    <h3>Workshop Name : {workshop.workshopName}</h3>\r\n    <h3>Workshop Identifier : {workshop._id}</h3>\r\n    <p>\r\n      1 Star:\r\n      <div className=\"progress-bar container\">\r\n        <div\r\n          className=\"progress-bar-inner bg-primary\"\r\n          style={{ width: `${calculatePercentage(workshop.workshopName, 1)}%` }}\r\n        >\r\n          <div className=\"progress-bar-value\">\r\n            {calculatePercentage(workshop.workshopName, 1)}%\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <br />\r\n      2 Stars:\r\n      <div className=\"progress-bar container\">\r\n        <div\r\n          className=\"progress-bar-inner bg-success\"\r\n          style={{ width: `${calculatePercentage(workshop.workshopName, 2)}%` }}\r\n        >\r\n          <div className=\"progress-bar-value\">\r\n            {calculatePercentage(workshop.workshopName, 2)}%\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <br />\r\n      3 Stars:\r\n      <div className=\"progress-bar container\">\r\n        <div\r\n          className=\"progress-bar-inner bg-warning\"\r\n          style={{ width: `${calculatePercentage(workshop.workshopName, 3)}%` }}\r\n        >\r\n          <div className=\"progress-bar-value\">\r\n            {calculatePercentage(workshop.workshopName, 3)}%\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <br />\r\n      4 Stars:\r\n      <div className=\"progress-bar container\">\r\n        <div\r\n          className=\"progress-bar-inner bg-info\"\r\n          style={{ width: `${calculatePercentage(workshop.workshopName, 4)}%` }}\r\n        >\r\n          <div className=\"progress-bar-value\">\r\n            {calculatePercentage(workshop.workshopName, 4)}%\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <br />\r\n      5 Stars:\r\n      <div className=\"progress-bar container\">\r\n        <div\r\n          className=\"progress-bar-inner bg-danger\"\r\n          style={{ width: `${calculatePercentage(workshop.workshopName, 5)}%` }}\r\n        >\r\n          <div className=\"progress-bar-value\">\r\n            {calculatePercentage(workshop.workshopName, 5)}%\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <br />\r\n      6 Stars:\r\n      <div className=\"progress-bar container\">\r\n        <div\r\n          className=\"progress-bar-inner bg-dark\"\r\n          style={{ width: `${calculatePercentage(workshop.workshopName, 6)}%` }}\r\n        >\r\n          <div className=\"progress-bar-value\">\r\n            {calculatePercentage(workshop.workshopName, 6)}%\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </p>\r\n  </div>\r\n))}\r\n\r\n        \r\n        <Footer />\r\n    </>\r\n  )\r\n}\r\n","D:\\PFA Project\\PFA new version 1\\PFA new version\\application\\src\\sections\\Header\\Header.js",[],[],"D:\\PFA Project\\PFA new version 1\\PFA new version\\application\\src\\sections\\Footer\\Footer.js",["178","179","180","181","182","183","184","185","186","187"],[],"import React from 'react'\r\nimport './Footer.css'\r\nimport facebook from \"../../images/social media/facebook.png\"\r\n\r\nexport const Footer = () => {\r\n  return (\r\n    <footer>\r\n\r\n      <h3 id='footer-title'>Enetcom Clubs : Stay Connected, Stay Motivated</h3>\r\n\r\n      <div className='footer-container'>\r\n       <h4 style={{margin:\"20px 0\", textAlign : \"center\", fontFamily:'serif', color : \"white\"}}>See where you can find our institution on Google Maps</h4>\r\n      <iframe src=\"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3274.713642334696!2d10.753458664541025!3d34.83829168334576!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x13002cd2cef7333d%3A0xaa3a1cf6d7fb55b0!2sEcole%20nationale%20d&#39;Electronique%20et%20des%20T%C3%A9l%C3%A9communications%20de%20Sfax%D8%8C%20Technopole%20Sfax%2C%20Route%20Tunis%20km%2011%2C%20cite%20Ons%2C%20Sfax!5e0!3m2!1sen!2stn!4v1679510311133!5m2!1sen!2stn\" width=\"900\" height=\"250\" id='map'></iframe>\r\n      </div>\r\n\r\n      <h4 style={{margin:\"20px 0\", textAlign : \"center\", fontFamily:'serif', color : \"white\", fontFamily:'serif'}}>You can follow your favourite clubs on Facebook and stay updated</h4>\r\n\r\n      <table id='clubs-table'>\r\n        <tr>\r\n          <td>\r\n            <img src={facebook} className='facebook-logo' />\r\n            <a href='https://www.facebook.com/profile.php?id=100083580901407'>ENET'Com Aero Modelisme club</a>\r\n          </td>\r\n          <td>\r\n            <img src={facebook} className='facebook-logo' />\r\n            <a href='https://www.facebook.com/profile.php?id=100086159481639'>ENET'Com Google Developer Students</a>\r\n          </td>\r\n          <td>\r\n            <img src={facebook} className='facebook-logo' />\r\n            <a href='https://www.facebook.com/profile.php?id=100086159481639'>IEEE ENET'Com Students</a>\r\n          </td>\r\n          <td>\r\n            <img src={facebook} className='facebook-logo' />\r\n            <a href='https://www.facebook.com/enetcomje'>ENET'Com Junior Entreprise</a>\r\n          </td>\r\n        </tr>\r\n        <tr>\r\n          <td>\r\n            <img src={facebook} className='facebook-logo' />\r\n            <a href='https://www.facebook.com/mtc.enetcom'>Microsoft Tech Club ENET'Com</a>\r\n          </td>\r\n          <td>\r\n            <img src={facebook} className='facebook-logo' />\r\n            <a href='https://www.facebook.com/NATEGENETCOM'>NATEG Tunisia ENET'Com Students</a>\r\n          </td>\r\n          <td>\r\n            <img src={facebook} className='facebook-logo' />\r\n            <a href='https://www.facebook.com/RadioEnetcom'>Orbeats Club Radio ENET'Com</a>\r\n          </td>\r\n          <td>\r\n            <img src={facebook} className='facebook-logo' />\r\n            <a href='https://www.facebook.com/CR.ENETCOM'>CR ENET'Com</a>\r\n          </td>\r\n        </tr>\r\n      </table>\r\n \r\n      <h5 style={{textAlign : \"center\", marginTop : \"10px\", fontFamily : \"fantasy\", letterSpacing : \"1px\", color : \"lightblue\"}} id='credit'>Designed & Developed by : Meiez Ben Romdhane & Safouen Ghzel 2 GT 1</h5>\r\n      <h5 style={{textAlign : \"center\", marginTop : \"10px\", fontFamily : \"fantasy\", letterSpacing : \"1px\", color : \"lightblue\"}}>© All copyrigths are conserved by owners</h5>\r\n\r\n    </footer>\r\n  )\r\n}\r\n","D:\\PFA Project\\PFA new version 1\\PFA new version\\application\\src\\sections\\Content\\Content.js",["188"],[],"import React from 'react'\r\nimport './Content.css'\r\nimport { Clubs } from '../../components/Clubs/Clubs'\r\nimport { ClubsContent } from '../../components/ClubsContent/ClubsContent'\r\nimport { Feedback } from '../../components/Feedback/Feedback'\r\nimport ImageSlider, { Events } from '../../components/Events/Events'\r\nimport ImageCarousel from '../../components/SlideIMG/ImageCarousel';\r\nimport Clubinti from '../../components/Clubinitiate/Clubinti'\r\nimport { FeedbackWorkshop } from '../../components/Feedback/FeedbackWorkshop'\r\n\r\nexport const Content = () => {\r\n  return (\r\n    <div className='content-container'> \r\n    <div style={{ display: \"flex\" }}>\r\n        <div className='Wc'>\r\n          <Clubinti />\r\n        </div>\r\n        <div>\r\n          <ImageCarousel />\r\n        </div>\r\n        \r\n        \r\n      </div> \r\n      <Clubs />\r\n      <ClubsContent />\r\n      <Events />\r\n      <Feedback />\r\n      <FeedbackWorkshop />\r\n    </div>\r\n  )\r\n}\r\n","D:\\PFA Project\\PFA new version 1\\PFA new version\\application\\src\\sections\\Content1\\Content1.js",[],[],"D:\\PFA Project\\PFA new version 1\\PFA new version\\application\\src\\Pages\\Organisation\\InscriptionsWorkshopsTable.js",[],[],"D:\\PFA Project\\PFA new version 1\\PFA new version\\application\\src\\Pages\\Organisation\\InscriptionsFormationsTable.js",[],[],"D:\\PFA Project\\PFA new version 1\\PFA new version\\application\\src\\Pages\\Organisation\\Sessions.js",["189"],[],"D:\\PFA Project\\PFA new version 1\\PFA new version\\application\\src\\components\\Navbar\\Navbar.js",["190","191","192","193","194","195","196","197","198","199","200","201","202","203","204"],[],"import './Navbar.css';\r\nimport Logo from '../../images/logo.png';\r\nimport { Link } from \"react-router-dom\";\r\nimport {FaHome, FaListUl, FaListOl, FaTable, FaComment, FaUser} from 'react-icons/fa'\r\nimport React, { useEffect, useState } from \"react\";\r\nexport const Navbar = () => {\r\n  \r\n  return (\r\n    <nav className=\"navbar navbar-expand-lg tertiary navbar-style\" >\r\n  <div className=\"container-fluid\">\r\n    <a className=\"navbar-brand\" href=\"#\">\r\n      <Link to=\"/home\"><img className='logo' src={Logo} /></Link>\r\n    </a>\r\n    <button className=\"navbar-toggler\" type=\"button\" data-bs-toggle=\"collapse\" data-bs-target=\"#navbarSupportedContent\" aria-controls=\"navbarSupportedContent\" aria-expanded=\"false\" aria-label=\"Toggle navigation\">\r\n      <span className=\"navbar-toggler-icon\"></span>\r\n    </button>\r\n    <div className=\"collapse navbar-collapse nav-items-container\" id=\"navbarSupportedContent\">\r\n      <ul className=\"navbar-nav me-auto mb-2 mb-lg-0\">\r\n        <li className=\"nav-item\">\r\n          <a className=\"nav-link active\" aria-current=\"page\">\r\n          <Link to=\"/home\"><FaHome className='icons' />Home</Link>\r\n          </a>\r\n        </li>\r\n        <li className=\"nav-item\">\r\n          <a className=\"nav-link\">\r\n            <Link to=\"/formations\"><FaListUl className='icons' />Formations</Link>\r\n          </a>\r\n        </li>\r\n        <li className=\"nav-item\">\r\n          <a className=\"nav-link\" aria-current=\"page\">\r\n          <Link to=\"/workshops\"><FaListOl className='icons' />Workshops</Link>\r\n          </a>\r\n        </li> \r\n        <li className=\"nav-item\">\r\n          <a className=\"nav-link\" aria-current=\"page\">\r\n          <Link to=\"/organisation\"><FaTable className='icons' />Organisation</Link>\r\n          </a>\r\n        </li>\r\n        \r\n       \r\n        <li className=\"nav-item\">\r\n            <div class=\"dropdown\">\r\n              <li class=\"nav-item\" type=\"button\" data-bs-toggle=\"dropdown\" aria-expanded=\"false\">\r\n              <a className=\"nav-link text-primary\" aria-current=\"page\" style={{fontWeight:\"bold\"}}>\r\n              <FaComment className='icons' />\r\n                Feedbacks\r\n                </a>\r\n              </li>\r\n              <ul class=\"dropdown-menu\">\r\n                <li><a class=\"dropdown-item\" href=\"#\">\r\n                <li className=\"nav-item\">\r\n                      <a className=\"nav-link\" aria-current=\"page\">\r\n                      <Link to=\"/feedback\">Formations Feedback</Link>\r\n                      </a>\r\n                    </li>\r\n                  </a></li>\r\n                <li><a cl